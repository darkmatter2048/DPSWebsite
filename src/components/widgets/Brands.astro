---
import { Icon } from 'astro-icon/components';
import type { Brands as Props } from '~/types';

import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
const {
  title = '',
  subtitle = '',
  tagline = '',
  icons = [],
  images = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <div class="flex flex-wrap justify-center gap-x-6 sm:gap-x-12 lg:gap-x-24">
    {icons && icons.map((icon) => <Icon name={icon} class="py-3 lg:py-5 w-12 h-auto mx-auto sm:mx-0 text-gray-500" />)}
    {
      images &&
        images.map(
          (image) =>
            image.src && (
              <a
                href={image.href || undefined}
                target={image.href ? '_blank' : undefined}
                rel={image.href ? 'noopener' : undefined}
                class:list={[{ 'pointer-events-none': !image.href }]}
              >
                <div class="flex justify-center items-center col-span-1 my-2 lg:my-4 py-2 px-3 sm:px-4 rounded-md dark:bg-gray-200 h-20 w-32 sm:h-24 sm:w-40 lg:h-28 lg:w-48 hover:shadow-md transition-shadow">
                  <img src={image.src} alt={image.alt || ''} class="max-h-full max-w-full object-contain" loading="lazy" />
                </div>
              </a>
            )
        )
    }
  </div>
</WidgetWrapper>
